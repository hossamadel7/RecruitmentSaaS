@model RecruitmentSaaS.Models.DTOs.SalesDashboardDto
@{
    ViewData["Title"] = "لوحة تيلي سيلز";
    ViewData["Subtitle"] = "مرحباً، هنا ملخص نشاطك اليوم";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card blue">
            <div class="stat-icon"><i class="bi bi-person-lines-fill"></i></div>
            <div class="stat-value">@Model.MyLeadsTotal</div>
            <div class="stat-label">إجمالي عملائي</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card amber">
            <div class="stat-icon"><i class="bi bi-person-exclamation"></i></div>
            <div class="stat-value">@Model.MyLeadsNew</div>
            <div class="stat-label">جدد لم يُتواصل معهم</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card green">
            <div class="stat-icon"><i class="bi bi-bell-fill"></i></div>
            <div class="stat-value">@Model.TodayReminders.Count</div>
            <div class="stat-label">تذكيرات اليوم</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card red">
            <div class="stat-icon"><i class="bi bi-trophy-fill"></i></div>
            <div class="stat-value">@Model.DealsThisMonth</div>
            <div class="stat-label">تحويلات هذا الشهر</div>
        </div>
    </div>
</div>

<div class="row g-3">

    <!-- Today's Reminders -->
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <div class="header-icon" style="background:#FEF2F2;color:#DC2626">
                    <i class="bi bi-bell-fill"></i>
                </div>
                تذكيرات اليوم
                @if (Model.TodayReminders.Any())
                {
                    <span class="badge ms-auto" style="background:#EF4444;color:#fff">@Model.TodayReminders.Count</span>
                }
            </div>
            @if (!Model.TodayReminders.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-check2-circle"></i>
                    <p>لا توجد تذكيرات اليوم</p>
                </div>
            }
            else
            {
                <div class="card-body p-0">
                    @foreach (var r in Model.TodayReminders)
                    {
                        <div class="d-flex align-items-center gap-3 px-4 py-3" style="border-bottom:1px solid #F1F5F9">
                            <div style="width:36px;height:36px;border-radius:50%;background:#FEF2F2;display:flex;align-items:center;justify-content:center;color:#DC2626;flex-shrink:0">
                                <i class="bi bi-alarm"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-size:13.5px;font-weight:600">@r.LeadName</div>
                                <div style="font-size:12px;color:var(--text-muted)">@r.LeadPhone — @r.Notes</div>
                            </div>
                            <div class="d-flex gap-1">
                                <a href="/TeleSales/LeadDetail/@r.LeadId" class="btn btn-sm btn-primary">عرض</a>
                                <form asp-action="DismissReminder" asp-controller="TeleSales" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reminderId" value="@r.Id" />
                                    <input type="hidden" name="leadId" value="@r.LeadId" />
                                    <button type="submit" class="btn btn-sm" style="border:1px solid var(--border);background:#fff">تجاهل</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Recent Leads -->
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <div class="header-icon" style="background:#EEF2FF;color:var(--primary)">
                    <i class="bi bi-person-lines-fill"></i>
                </div>
                آخر عملائي
                <a href="/TeleSales/Leads" class="btn btn-sm btn-primary ms-auto">عرض الكل</a>
            </div>
            @if (!Model.RecentLeads.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p>لا يوجد عملاء بعد — <a href="/TeleSales/Pool">تصفح بنك العملاء</a></p>
                </div>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th>الاسم</th>
                                <th>الحالة</th>
                                <th>آخر تواصل</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lead in Model.RecentLeads)
                            {
                                var (stClass, stName) = lead.Status switch {
                                    1 => ("badge-status-1", "جديد"),
                                    2 => ("badge-status-2", "تم التواصل"),
                                    3 => ("badge-status-3", "استجاب"),
                                    4 => ("badge-status-4", "مهتم"),
                                    5 => ("badge-status-5", "موعد مجدول"),
                                    6 => ("badge-status-6", "زار المكتب"),
                                    7 => ("badge-status-7", "تم التحويل"),
                                    8 => ("badge-status-8", "خسارة"),
                                    _ => ("badge-status-1", "غير معروف")
                                };
                                <tr>
                                    <td>
                                        <span style="font-size:11px;font-weight:700;color:var(--text-muted);background:#F1F5F9;padding:3px 8px;border-radius:6px">
                                            @lead.LeadCode
                                        </span>
                                    </td>
                                    <td style="font-weight:600">@lead.FullName</td>
                                    <td><span class="badge @stClass">@stName</span></td>
                                    <td style="color:var(--text-muted);font-size:12.5px">
                                        @(lead.LastContactedAt.HasValue ? lead.LastContactedAt.Value.ToString("dd/MM/yyyy") : "—")
                                    </td>
                                    <td>
                                        <a href="/TeleSales/LeadDetail/@lead.Id"
                                           style="font-size:12px;font-weight:600;color:var(--primary);text-decoration:none;padding:5px 12px;border:1px solid var(--primary);border-radius:6px">
                                            <i class="bi bi-eye"></i> تفاصيل
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>
