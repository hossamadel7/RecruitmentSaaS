@using RecruitmentSaaS.Models.Entities
@{
    ViewData["Title"] = "لوحة مدير التيلي سيلز";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int selMonth = ViewBag.SelMonth;
    int selYear = ViewBag.SelYear;
    string mLabel = ViewBag.MonthLabel;
    string pLabel = ViewBag.PrevMonthLabel ?? "";
    string mgrName = ViewBag.ManagerName ?? "";

    int totLeads = ViewBag.TotalLeads;
    int totConv = ViewBag.TotalConverted;
    double totRate = ViewBag.TotalRate;
    int prevLeads = ViewBag.PrevTotalLeads;
    int prevConv = ViewBag.PrevTotalConverted;
    double prevRate = ViewBag.PrevTotalRate;
    int lTrend = ViewBag.LeadsTrend;
    int cTrend = ViewBag.ConvTrend;
    double rTrend = ViewBag.RateTrend;

    var teamStats = ViewBag.TeamStats as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var breakdown = ViewBag.TeamStatusBreakdown as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var myTeam = ViewBag.MyTeam as IEnumerable<User> ?? Enumerable.Empty<User>();

    string[] statusLabels = ViewBag.StatusLabels as string[] ?? new[] { "", "عميل جديد", "تم التواصل", "مهتم", "يفكر", "وعد بالزيارة", "زيارة", "تحويل", "ملغى" };
    string[] statusColors = { "", "#3b82f6", "#8b5cf6", "#0ea5e9", "#f59e0b", "#22c55e", "#ec4899", "#6366f1", "#dc2626" };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon" style="background:linear-gradient(135deg,#fdf4ff,#f3e8ff);">📊</div>
        <div>
            <h1 class="page-title">لوحة أداء الفريق</h1>
            <p style="color:var(--text-muted);font-size:.8rem;margin:2px 0 0;">@mgrName · @myTeam.Count() موظف تيلي سيلز</p>
        </div>
    </div>
</div>

@* ── Month Selector ─────────────────────────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" action="/TeleSalesManager/Index" class="d-flex align-items-center gap-3 flex-wrap">
            <span style="font-size:.82rem;color:var(--text-muted);font-weight:600;">📅 الشهر:</span>
            <select name="month" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                @for (int m = 1; m <= 12; m++)
                {
                    var ml = new DateTime(selYear, m, 1).ToString("MMMM", new System.Globalization.CultureInfo("ar-EG"));
                    if (m == selMonth)
                    {
                        <option value="@m" selected>@ml</option>
                    }
                    else
                    {
                        <option value="@m">@ml</option>
                    }
                }
            </select>
            <select name="year" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                @for (int y = DateTime.UtcNow.Year; y >= DateTime.UtcNow.Year - 2; y--)
                {
                    if (y == selYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
            <span style="font-size:.78rem;color:var(--text-muted);margin-right:auto;">
                مقارنة <strong>@mLabel</strong> بـ <strong>@pLabel</strong>
            </span>
        </form>
    </div>
</div>

@if (!myTeam.Any())
{
    <div class="card">
        <div class="card-body" style="padding:48px;text-align:center;">
            <div style="font-size:2.5rem;margin-bottom:12px;">👥</div>
            <div style="font-weight:700;font-size:1rem;margin-bottom:6px;">لم يتم تعيين فريق بعد</div>
            <div style="color:var(--text-muted);font-size:.85rem;">يرجى التواصل مع المدير لتعيين موظفي التيلي سيلز لحسابك</div>
        </div>
    </div>
}
else
{
    @* ── Team Summary Cards ──────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div style="font-size:.72rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">ليدز الفريق</div>
                    <div style="font-size:2rem;font-weight:700;line-height:1;color:#3b82f6;">@totLeads.ToString("N0")</div>
                    <div style="font-size:.72rem;margin-top:6px;">
                        @{
                            string lTrendColor = lTrend >= 0 ? "#22c55e" : "#ef4444"; string lTrendIcon = lTrend >= 0 ? "▲" : "▼";
                        }
                        <span style="color:@lTrendColor;font-weight:700;">@lTrendIcon @Math.Abs(lTrend)</span>
                        <span style="color:var(--text-muted);"> مقارنة بـ @pLabel (@prevLeads)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div style="font-size:.72rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">تحويلات</div>
                    <div style="font-size:2rem;font-weight:700;line-height:1;color:#22c55e;">@totConv.ToString("N0")</div>
                    <div style="font-size:.72rem;margin-top:6px;">
                        @{
                            string cTrendColor = cTrend >= 0 ? "#22c55e" : "#ef4444"; string cTrendIcon = cTrend >= 0 ? "▲" : "▼";
                        }
                        <span style="color:@cTrendColor;font-weight:700;">@cTrendIcon @Math.Abs(cTrend)</span>
                        <span style="color:var(--text-muted);"> مقارنة بـ @pLabel (@prevConv)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div style="font-size:.72rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">معدل التحويل</div>
                    <div style="font-size:2rem;font-weight:700;line-height:1;color:@(totRate >= 20 ? "#22c55e" : totRate >= 10 ? "#f59e0b" : "#ef4444");">
                        @totRate<span style="font-size:1rem;">%</span>
                    </div>
                    <div style="font-size:.72rem;margin-top:6px;">
                        @{
                            string rTrendColor = rTrend >= 0 ? "#22c55e" : "#ef4444"; string rTrendIcon = rTrend >= 0 ? "▲" : "▼";
                        }
                        <span style="color:@rTrendColor;font-weight:700;">@rTrendIcon @Math.Abs(rTrend)%</span>
                        <span style="color:var(--text-muted);"> كان @prevRate% في @pLabel</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div style="font-size:.72rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">توزيع الحالات</div>
                    @foreach (var item in breakdown)
                    {
                        int s = (int)item.Status;
                        string lbl = s >= 1 && s < statusLabels.Length ? statusLabels[s] : $"حالة {s}";
                        string col = s >= 1 && s < statusColors.Length ? statusColors[s] : "#64748b";
                        int cnt = (int)item.Count;
                        double pct = totLeads > 0 ? Math.Round((double)cnt / totLeads * 100, 0) : 0;
                        <div style="display:flex;align-items:center;gap:6px;font-size:.72rem;margin-bottom:3px;">
                            <span style="width:7px;height:7px;border-radius:50%;background:@col;flex-shrink:0;"></span>
                            <span style="flex:1;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@lbl</span>
                            <span style="font-weight:700;">@cnt</span>
                            <span style="color:var(--text-muted);">@pct%</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Performance Comparison Table ────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-body">
            <div style="font-size:.82rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:16px;">
                🏆 مقارنة أداء الفريق — @mLabel
            </div>

            @{
                int rank = 0;
            }
            @foreach (var s in teamStats)
            {
                rank++;
                string medal = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : $"#{rank}";
                int curT = (int)s.CurTotal;
                int curC = (int)s.CurConverted;
                double curR = (double)s.CurRate;
                int prevT = (int)s.PrevTotal;
                int prevC = (int)s.PrevConverted;
                double prevR = (double)s.PrevRate;
                int lTrnd = (int)s.LeadsTrend;
                int cTrnd = (int)s.ConvTrend;
                double rTrnd = (double)s.RateTrend;
                string mName = (string)s.MemberName;
                Guid mId = (Guid)(s.MemberId ?? Guid.Empty);
                int maxLeads = (int)teamStats.First().CurTotal;
                double barW = maxLeads > 0 ? Math.Round((double)curT / maxLeads * 100, 0) : 0;

                <div style="border:1px solid var(--bs-border-color,#e2e8f0);border-radius:12px;padding:16px;margin-bottom:12px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                        <span style="font-size:1.2rem;">@medal</span>
                        <span style="font-weight:700;font-size:.95rem;flex:1;">@mName</span>
                        <a href="/TeleSalesManager/MemberLeads/@mId?month=@selMonth&year=@selYear"
                           class="btn btn-ghost btn-sm" style="font-size:.75rem;">
                            عرض الليدز <i class="bi bi-arrow-left"></i>
                        </a>
                    </div>

                    @* Progress bar *@
                    <div style="background:#e2e8f0;border-radius:99px;height:6px;overflow:hidden;margin-bottom:12px;">
                        <div style="width:@barW%;background:@(rank==1?"#f59e0b":rank==2?"#94a3b8":rank==3?"#cd7c2f":"#3b82f6");height:100%;border-radius:99px;"></div>
                    </div>

                    @* Stats comparison row *@
                    <div class="row g-2" style="font-size:.8rem;">
                        <div class="col-4">
                            <div style="color:var(--text-muted);margin-bottom:2px;">ليدز هذا الشهر</div>
                            <div style="font-weight:700;font-size:1.1rem;color:#3b82f6;">@curT</div>
                            <div style="font-size:.72rem;">
                                @{
                                    string lt = lTrnd >= 0 ? "#22c55e" : "#ef4444"; string li = lTrnd >= 0 ? "▲" : "▼";
                                }
                                <span style="color:@lt;font-weight:600;">@li @Math.Abs(lTrnd)</span>
                                <span style="color:var(--text-muted);"> كان @prevT</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div style="color:var(--text-muted);margin-bottom:2px;">تحويلات</div>
                            <div style="font-weight:700;font-size:1.1rem;color:#22c55e;">@curC</div>
                            <div style="font-size:.72rem;">
                                @{
                                    string ct = cTrnd >= 0 ? "#22c55e" : "#ef4444"; string ci = cTrnd >= 0 ? "▲" : "▼";
                                }
                                <span style="color:@ct;font-weight:600;">@ci @Math.Abs(cTrnd)</span>
                                <span style="color:var(--text-muted);"> كان @prevC</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div style="color:var(--text-muted);margin-bottom:2px;">معدل التحويل</div>
                            <div style="font-weight:700;font-size:1.1rem;color:@(curR>=20?"#22c55e":curR>=10?"#f59e0b":"#ef4444");">@curR%</div>
                            <div style="font-size:.72rem;">
                                @{
                                    string rt = rTrnd >= 0 ? "#22c55e" : "#ef4444"; string ri = rTrnd >= 0 ? "▲" : "▼";
                                }
                                <span style="color:@rt;font-weight:600;">@ri @Math.Abs(rTrnd)%</span>
                                <span style="color:var(--text-muted);"> كان @prevR%</span>
                            </div>
                        </div>
                    </div>

                    @* Status breakdown for this member *@
                    @if (s.ByStatus != null)
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
                            @foreach (var st in (IEnumerable<dynamic>)s.ByStatus)
                            {
                                int stCode = (int)st.Status;
                                int stCnt = (int)st.Count;
                                string stLbl = stCode >= 1 && stCode < statusLabels.Length ? statusLabels[stCode] : $"حالة {stCode}";
                                string stCol = stCode >= 1 && stCode < statusColors.Length ? statusColors[stCode] : "#64748b";
                                <span style="background:@(stCol+"18");color:@stCol;border:1px solid @(stCol+"40");font-size:.68rem;padding:2px 8px;border-radius:99px;font-weight:700;">
                                    @stLbl: @stCnt
                                </span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
