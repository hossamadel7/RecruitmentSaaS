@{
    ViewData["Title"] = "لوحة الاستقبال";
    ViewData["Subtitle"] = "زيارات اليوم";
    var todayVisits = ViewBag.TodayVisits as List<RecruitmentSaaS.Models.DTOs.WalkInSearchResultDto>
                     ?? new List<RecruitmentSaaS.Models.DTOs.WalkInSearchResultDto>();
    var todayCount = (int)(ViewBag.TodayVisitsCount ?? 0);
}

<!-- Stat -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card blue">
            <div class="stat-icon"><i class="bi bi-person-check-fill"></i></div>
            <div class="stat-value">@todayCount</div>
            <div class="stat-label">زيارات اليوم</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card green">
            <div class="stat-icon"><i class="bi bi-person-plus-fill"></i></div>
            <div class="stat-value">@todayVisits.Count(v => !v.IsConverted)</div>
            <div class="stat-label">في انتظار المقابلة</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card amber">
            <div class="stat-icon"><i class="bi bi-arrow-repeat"></i></div>
            <div class="stat-value">@todayVisits.Count(v => v.IsConverted)</div>
            <div class="stat-label">تم تحويلهم اليوم</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card red">
            <div class="stat-icon"><i class="bi bi-plus-circle-fill"></i></div>
            <div class="stat-value">
                <a href="/Reception/WalkIn" style="color:inherit;text-decoration:none">تسجيل</a>
            </div>
            <div class="stat-label">تسجيل زيارة جديدة</div>
        </div>
    </div>
</div>

<!-- Today's Visits -->
<div class="card">
    <div class="card-header">
        <div class="header-icon" style="background:#EEF2FF;color:var(--primary)">
            <i class="bi bi-calendar-check-fill"></i>
        </div>
        زيارات اليوم
        @if (todayCount > 0)
        {
            <span class="badge ms-1" style="background:var(--primary);color:#fff">@todayCount</span>
        }
        <a href="/Reception/WalkIn" class="btn btn-sm btn-primary ms-auto">
            <i class="bi bi-plus-lg"></i> تسجيل زيارة
        </a>
    </div>

    @if (!todayVisits.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <p>لا توجد زيارات مسجلة اليوم</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto">
            <table class="table">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>الهاتف</th>
                        <th>الحالة</th>
                        <th>مندوب المبيعات</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in todayVisits)
                    {
                        var (stClass, stName) = v.Status switch {
                            6 => ("badge-status-6", "في الانتظار"),
                            7 => ("badge-status-7", "تم التحويل"),
                            _ => ("badge-status-1", "غير معروف")
                        };
                        <tr>
                            <td>
                                <span style="font-size:11px;font-weight:700;color:var(--text-muted);background:#F1F5F9;padding:3px 8px;border-radius:6px">
                                    @v.LeadCode
                                </span>
                            </td>
                            <td style="font-weight:600">@v.FullName</td>
                            <td style="color:var(--text-muted);font-size:13px;direction:ltr;text-align:right">@v.Phone</td>
                            <td><span class="badge @stClass">@stName</span></td>
                            <td style="font-size:13px;color:var(--text-muted)">
                                @(v.AssignedSalesName ?? "—")
                            </td>
                            <td>
                                <a href="/Reception/WalkIn?phone=@v.Phone"
                                   style="font-size:12px;font-weight:600;color:var(--primary);text-decoration:none;padding:5px 12px;border:1px solid var(--primary);border-radius:6px">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
