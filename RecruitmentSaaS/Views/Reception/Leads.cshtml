@model List<RecruitmentSaaS.Models.DTOs.LeadListItemDto>
@{
    ViewData["Title"] = "سجل الزيارات";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">سجل الزيارات</h1>
        <div class="page-header-sub">@totalCount زيارة مسجلة</div>
    </div>
    <a href="/Reception/WalkIn" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> تسجيل زيارة
    </a>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <p>لا توجد زيارات مسجلة</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto">
            <table class="table">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>الهاتف</th>
                        <th>الحالة</th>
                        <th>تاريخ التسجيل</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model)
                    {
                        var (stClass, stName) = lead.Status switch {
                            1 => ("badge-status-1", "جديد"),
                            2 => ("badge-status-2", "تم التواصل"),
                            3 => ("badge-status-3", "استجاب"),
                            4 => ("badge-status-4", "مهتم"),
                            5 => ("badge-status-5", "موعد مجدول"),
                            6 => ("badge-status-6", "زار المكتب"),
                            7 => ("badge-status-7", "تم التحويل"),
                            8 => ("badge-status-8", "خسارة"),
                            _ => ("badge-status-1", "غير معروف")
                        };
                        <tr>
                            <td>
                                <span style="font-size:11px;font-weight:700;color:var(--text-muted);background:#F1F5F9;padding:3px 8px;border-radius:6px">
                                    @lead.LeadCode
                                </span>
                            </td>
                            <td style="font-weight:600">@lead.FullName</td>
                            <td style="color:var(--text-muted);font-size:13px;direction:ltr;text-align:right">@lead.Phone</td>
                            <td><span class="badge @stClass">@stName</span></td>
                            <td style="color:var(--text-muted);font-size:12.5px">@lead.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="/Reception/WalkIn?phone=@lead.Phone"
                                   style="font-size:12px;font-weight:600;color:var(--primary);text-decoration:none;padding:5px 12px;border:1px solid var(--primary);border-radius:6px">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalCount > 20)
        {
            <div class="d-flex justify-content-center gap-2 p-3">
                @if (currentPage > 1)
                {
                    <a href="/Reception/Leads?page=@(currentPage - 1)"
                       class="btn btn-sm" style="border:1px solid var(--border)">السابق</a>
                }
                <span class="btn btn-sm btn-primary">@currentPage</span>
                @if (Model.Count == 20)
                {
                    <a href="/Reception/Leads?page=@(currentPage + 1)"
                       class="btn btn-sm" style="border:1px solid var(--border)">التالي</a>
                }
            </div>
        }
    }
</div>
