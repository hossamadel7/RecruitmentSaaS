    <!-- ══════════════════ WHATSAPP FAB ══════════════════ -->
    <a class="wp-fab" href="https://wa.me/@wpNumber?text=مرحباً" id="wpFab" target="_blank" rel="noopener noreferrer" aria-label="@wpLabel">
        <i class="bi bi-whatsapp wp-icon"></i>
        <span class="wp-text">@wpLabel</span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            'use strict';

            /* ── Navbar scroll effect + sticky CTA ──────────────── */
            const navbar = document.getElementById('navbar');
            window.addEventListener('scroll', () => {
                navbar.classList.toggle('scrolled', window.scrollY > 60);
            }, { passive: true });

            /* ── Scroll reveal (translate + scale variants) ─────── */
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        e.target.classList.add('visible');
                        observer.unobserve(e.target);
                    }
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal, .reveal-scale').forEach(el => observer.observe(el));

            /* ── WhatsApp dynamic prefill ────────────────────────── */
            const wpNumber   = '@wpNumber';
            const wpFab      = document.getElementById('wpFab');
            const navWp      = document.getElementById('navWp');
            const heroWp     = document.getElementById('heroWp');
            const nameInput  = document.getElementById('fullName');
            const phoneInput = document.getElementById('phone');
            const notesInput = document.getElementById('notes');

            function buildWpUrl() {
                const name  = nameInput  ? nameInput.value.trim()  : '';
                const phone = phoneInput ? phoneInput.value.trim() : '';
                const note  = notesInput ? notesInput.value.trim() : '';
                let msg = 'مرحباً، أرغب في الاستفسار عن فرص العمل عبر الفهد العربي';
                if (name)  msg += ' — الاسم: ' + name;
                if (phone) msg += ' — الهاتف: ' + phone;
                if (note)  msg += ' — ' + (note.length > 60 ? note.substring(0, 60) + '...' : note);
                return 'https://wa.me/' + wpNumber + '?text=' + encodeURIComponent(msg);
            }
            function updateWpLinks() {
                const url = buildWpUrl();
                [wpFab, navWp, heroWp].forEach(el => { if (el) el.setAttribute('href', url); });
            }
            [nameInput, phoneInput, notesInput].forEach(el => { if (el) el.addEventListener('input', updateWpLinks); });
            updateWpLinks();

            /* ── Prevent double submit ───────────────────────────── */
            const leadForm  = document.getElementById('leadForm');
            const submitBtn = document.getElementById('submitBtn');
            if (leadForm && submitBtn) {
                leadForm.addEventListener('submit', function () {
                    if (!leadForm.checkValidity()) return;
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>جارٍ الإرسال...';
                });
            }

            /* ── Smooth scroll anchors ───────────────────────────── */
            document.querySelectorAll('a[href^="#"]').forEach(a => {
                a.addEventListener('click', function (e) {
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
                });
            });

            /* ── Testimonials mobile carousel arrows ─────────────── */
            const carouselTrack = document.getElementById('tCarouselTrack');
            const prevBtn = document.getElementById('tPrev');
            const nextBtn = document.getElementById('tNext');
            if (carouselTrack && prevBtn && nextBtn) {
                function getCardWidth() {
                    const card = carouselTrack.querySelector('.tcard');
                    if (!card) return 300;
                    const gap = 16;
                    return card.offsetWidth + gap;
                }
                prevBtn.addEventListener('click', () => {
                    carouselTrack.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
                });
                nextBtn.addEventListener('click', () => {
                    carouselTrack.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
                });
            }

            /* ── FAQ accordion ───────────────────────────────────── */
            document.querySelectorAll('.faq-question').forEach(q => {
                q.addEventListener('click', function () {
                    const item = this.closest('.faq-item');
                    const isOpen = item.classList.contains('open');
                    // close all
                    document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
                    // open this one if it was closed
                    if (!isOpen) item.classList.add('open');
                });
            });

            /* ── Input focus: animate icon colour ───────────────── */
            document.querySelectorAll('.input-icon-wrap .form-control').forEach(input => {
                const icon = input.parentElement.querySelector('.input-icon');
                if (!icon) return;
                input.addEventListener('focus',  () => { icon.style.color = 'var(--blue)'; });
                input.addEventListener('blur',   () => { icon.style.color = ''; });
            });

        })();
    </script>

</body>
</html>
