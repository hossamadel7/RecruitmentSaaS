@using RecruitmentSaaS.Models.Entities
@model List<Commission>
@{
    ViewData["Title"] = "العمولات";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int  page         = ViewBag.Page;
    int  totalPages   = ViewBag.TotalPages;
    int  total        = ViewBag.Total;
    byte statusFilter = ViewBag.StatusFilter;

    // CommissionStatus: 1=Pending, 2=Approved(Admin), 3=Paid(Accountant), 4=Reversed
    string[] statusLabels = { "", "انتظار الإدارة", "معتمدة — جاهزة للصرف", "مصروفة", "مُعكوسة" };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon" style="background:linear-gradient(135deg,#fffbeb,#fde68a);">🏆</div>
        <div>
            <h1 class="page-title">العمولات</h1>
            <p style="color:var(--text-muted);font-size:.8rem;margin:2px 0 0;">@total عمولة</p>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-4" data-auto-dismiss="4000">✅ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4" data-auto-dismiss="4000">❌ @TempData["Error"]</div>
}

@* Status filter tabs *@
<div class="d-flex gap-2 mb-4 flex-wrap">
    @{
        var tabs = new[] {
            ("معتمدة — جاهزة للصرف", (byte)2, "#f59e0b"),
            ("مصروفة", (byte)3, "#16a34a"),
            ("انتظار الإدارة", (byte)1, "#64748b"),
            ("مُعكوسة", (byte)4, "#dc2626"),
        };
    }
    @foreach (var (label, val, color) in tabs)
    {
        bool active = statusFilter == val;
        <a href="?status=@val" style="padding:7px 16px;border-radius:99px;font-size:.8rem;font-weight:700;
               text-decoration:none;transition:all .15s;
               background:@(active ? color : "var(--card-bg)");
               color:@(active ? "#fff" : "var(--text-muted)");
               border:1.5px solid @(active ? color : "var(--border)");">
            @label
        </a>
    }
</div>

<div class="card">
    @if (Model.Any())
    {
        @if (statusFilter == 2)
        {
            <div style="padding:12px 20px;background:#fffbeb;border-bottom:1px solid #fde68a;font-size:.82rem;color:#92400e;font-weight:600;">
                ⚠️ هذه العمولات اعتمدتها الإدارة وتحتاج إلى صرفها للموظفين
            </div>
        }

        <div style="overflow-x:auto;">
            <table class="table">
                <thead>
                    <tr>
                        <th>موظف المبيعات</th>
                        <th>المرشح / الصفقة</th>
                        <th>شهر العمولة</th>
                        <th>عدد الصفقات</th>
                        <th>مبلغ العمولة</th>
                        <th>اعتمد بواسطة</th>
                        <th>الحالة</th>
                        <th>إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar avatar-sm avatar-purple">
                                        @(c.SalesUser?.FullName?.FirstOrDefault() ?? '؟')
                                    </div>
                                    <div>
                                        <div style="font-weight:700;font-size:.875rem;">@c.SalesUser?.FullName</div>
                                        <div style="font-size:.72rem;color:var(--text-faint);">مبيعات مكتبية</div>
                                    </div>
                                </div>
                            </td>
                            <td style="font-size:.82rem;">
                                <div style="font-weight:600;">@c.Candidate?.FullName</div>
                                <div style="color:var(--text-faint);">@c.Candidate?.JobPackage?.Name</div>
                            </td>
                            <td style="font-size:.82rem;white-space:nowrap;">
                                @c.CommissionMonth.ToString("MM/yyyy")
                            </td>
                            <td style="text-align:center;font-weight:700;">@c.DealsThisMonth</td>
                            <td>
                                <span style="font-weight:800;color:#b45309;font-size:.95rem;">
                                    @c.AmountEgp.ToString("N0") ج.م
                                </span>
                            </td>
                            <td style="font-size:.82rem;">
                                @if (c.ApprovedBy != null)
                                {
                                    @c.ApprovedBy.FullName
                                    <div style="font-size:.72rem;color:var(--text-faint);">
                                        @c.ApprovedAt?.ToString("dd/MM/yyyy")
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--text-faint);">—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var (bg, col, border) = c.Status switch {
                                        1 => ("#f1f5f9", "#64748b", "#e2e8f0"),
                                        2 => ("#fffbeb", "#b45309", "#fde68a"),
                                        3 => ("#f0fdf4", "#16a34a", "#bbf7d0"),
                                        4 => ("#fef2f2", "#dc2626", "#fecaca"),
                                        _ => ("#f1f5f9", "#64748b", "#e2e8f0")
                                    };
                                }
                                <span class="badge-pill" style="background:@bg;color:@col;border:1px solid @border;">
                                    @(c.Status < statusLabels.Length ? statusLabels[c.Status] : "—")
                                </span>
                            </td>
                            <td>
                                @if (c.Status == 2)
                                {
                                    <form method="post" action="/Accountant/PayCommission" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commissionId" value="@c.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:#fffbeb;color:#b45309;border:1px solid #fde68a;"
                                                data-confirm
                                                data-confirm-title="تسجيل صرف العمولة"
                                                data-confirm-message="تسجيل صرف @c.AmountEgp.ToString("N0") ج.م لـ @c.SalesUser?.FullName؟"
                                                data-confirm-ok="صرف"
                                                data-confirm-class="btn-warning"
                                                data-confirm-icon="🏆">
                                            تسجيل الصرف
                                        </button>
                                    </form>
                                }
                                else if (c.Status == 3)
                                {
                                    <span style="font-size:.78rem;color:var(--text-faint);">
                                        صُرفت @c.PaidAt?.ToString("dd/MM")
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--text-faint);">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (statusFilter == 2 && Model.Any())
        {
            <div class="card-footer d-flex align-items-center justify-content-between">
                <div style="font-weight:700;color:#b45309;">
                    إجمالي العمولات المستحقة:
                    @Model.Sum(c => c.AmountEgp).ToString("N0") ج.م
                </div>
                <div style="font-size:.8rem;color:var(--text-muted);">@total عمولة جاهزة للصرف</div>
            </div>
        }

        @if (totalPages > 1)
        {
            <div class="card-footer d-flex justify-content-center">
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @if (page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?status=@statusFilter&page=@(page-1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                        @for (int p = Math.Max(1, page - 2); p <= Math.Min(totalPages, page + 2); p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" href="?status=@statusFilter&page=@p">@p</a>
                            </li>
                        }
                        @if (page < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?status=@statusFilter&page=@(page+1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">🏆</div>
            <div class="empty-state-title">لا توجد عمولات</div>
            <div class="empty-state-text">
                @if (statusFilter == 2)
                {
                    <text>لا توجد عمولات معتمدة من الإدارة في انتظار الصرف</text>
                }
                else
                {
                    <text>لا توجد عمولات بهذه الحالة</text>
                }
            </div>
        </div>
    }
</div>
