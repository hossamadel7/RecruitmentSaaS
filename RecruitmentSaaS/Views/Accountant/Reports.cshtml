@{
    ViewData["Title"] = "التقارير المالية";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int month = ViewBag.Month;
    int year = ViewBag.Year;
    decimal totalCollected = ViewBag.TotalCollected;
    decimal refundsThisMonth = ViewBag.RefundsThisMonth;
    decimal commissionsThisMonth = ViewBag.CommissionsThisMonth;
    decimal salariesThisMonth = (decimal)(ViewBag.SalariesThisMonth ?? 0m);
    int candidatesThisMonth = ViewBag.CandidatesThisMonth;
    int completedThisMonth = ViewBag.CompletedThisMonth;

    var paymentsByMethod = (IEnumerable<dynamic>)ViewBag.PaymentsThisMonth;
    var bySales = (IEnumerable<dynamic>)ViewBag.BySales;
    var salaryDetails = ViewBag.SalaryDetails as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();

    string[] months = { "", "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو",
                         "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر" };
    string[] payMethods = { "", "كاش", "تحويل بنكي", "بطاقة", "شيك" };
    string[] roleNames = { "", "", "استقبال", "تيلي سيلز", "محاسب", "عمليات", "مبيعات مكتبية" };

    decimal totalExpenses = refundsThisMonth + commissionsThisMonth + salariesThisMonth;
    decimal netRevenue = totalCollected - totalExpenses;

    string totalCollectedText = totalCollected.ToString("N0");
    string refundsText = refundsThisMonth.ToString("N0");
    string commissionsText = commissionsThisMonth.ToString("N0");
    string salariesText = salariesThisMonth.ToString("N0");
    string totalExpensesText = totalExpenses.ToString("N0");
    string netRevenueText = netRevenue.ToString("N0");

    string netRevenueBg = netRevenue >= 0 ? "#f0fdf4" : "#fef2f2";
    string netRevenueColor = netRevenue >= 0 ? "#16a34a" : "#dc2626";

    string profitBg = netRevenue >= 0 ? "#eff6ff" : "#fef2f2";
    string profitBorder = netRevenue >= 0 ? "#2563eb" : "#dc2626";
    string profitText = netRevenue >= 0 ? "#1d4ed8" : "#dc2626";
}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon" style="background:linear-gradient(135deg,#f5f3ff,#ede9fe);">📊</div>
        <div>
            <h1 class="page-title">التقارير المالية</h1>
            <p style="color:var(--text-muted);font-size:.8rem;margin:2px 0 0;">@months[month] @year</p>
        </div>
    </div>
    <form method="get" class="d-flex gap-2 align-items-center">
        <select name="month" class="form-select form-select-sm" style="width:120px;">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(m == month ? "selected" : null)">@months[m]</option>
            }
        </select>
        <select name="year" class="form-select form-select-sm" style="width:90px;">
            @for (int y = DateTime.UtcNow.Year; y >= DateTime.UtcNow.Year - 3; y--)
            {
                <option value="@y" selected="@(y == year ? "selected" : null)">@y</option>
            }
        </select>
        <button type="submit" class="btn btn-primary btn-sm">عرض</button>
    </form>
</div>

@* ── Summary stat cards ── *@
<div class="row g-3 mb-4">
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0fdf4;color:#16a34a;">💰</div>
            <div>
                <div class="stat-value" style="color:#16a34a;font-size:1rem;">@totalCollectedText</div>
                <div class="stat-label">إجمالي المحصّل (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef2f2;color:#dc2626;">↩️</div>
            <div>
                <div class="stat-value" style="color:#dc2626;font-size:1rem;">@refundsText</div>
                <div class="stat-label">مردودات منفّذة (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fffbeb;color:#b45309;">🏆</div>
            <div>
                <div class="stat-value" style="color:#b45309;font-size:1rem;">@commissionsText</div>
                <div class="stat-label">عمولات مصروفة (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f5f3ff;color:#7c3aed;">💵</div>
            <div>
                <div class="stat-value" style="color:#7c3aed;font-size:1rem;">@salariesText</div>
                <div class="stat-label">مرتبات مصروفة (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:@netRevenueBg;color:@netRevenueColor;">📈</div>
            <div>
                <div class="stat-value" style="color:@netRevenueColor;font-size:1rem;">@netRevenueText</div>
                <div class="stat-label">صافي الربح (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff;color:#2563eb;">👤</div>
            <div>
                <div class="stat-value">@candidatesThisMonth</div>
                <div class="stat-label">مرشحون جدد</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    @* ── Payments by method ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <span class="card-title">💳 المدفوعات حسب طريقة السداد</span>
            </div>
            <div class="card-body p-0">
                @if (paymentsByMethod.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>طريقة الدفع</th>
                                <th>عدد الدفعات</th>
                                <th>الإجمالي</th>
                                <th>النسبة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in paymentsByMethod)
                            {
                                int method = (int)row.Method;
                                decimal rowTotal = (decimal)row.Total;
                                int count = (int)row.Count;
                                int pct = totalCollected > 0 ? (int)(rowTotal / totalCollected * 100) : 0;
                                string methodName = method >= 1 && method < payMethods.Length ? payMethods[method] : "أخرى";
                                string rowTotalText = rowTotal.ToString("N0");
                                <tr>
                                    <td style="font-weight:600;">@methodName</td>
                                    <td style="text-align:center;">@count</td>
                                    <td style="font-weight:700;color:#16a34a;">@rowTotalText ج.م</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="flex:1;height:6px;background:#e2e8f0;border-radius:99px;">
                                                <div style="width:@pct%;height:100%;background:#2563eb;border-radius:99px;"></div>
                                            </div>
                                            <span style="font-size:.72rem;color:var(--text-muted);">@pct%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f8fafc;font-weight:800;">
                                <td>الإجمالي</td>
                                <td style="text-align:center;">@paymentsByMethod.Sum(r => (int)r.Count)</td>
                                <td style="color:#16a34a;">@totalCollectedText ج.م</td>
                                <td>100%</td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="empty-state" style="padding:32px;">
                        <div class="empty-state-icon" style="font-size:2rem;">💳</div>
                        <div class="empty-state-title">لا توجد مدفوعات هذا الشهر</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── By sales user ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <span class="card-title">🏅 أداء المبيعات المكتبية</span>
            </div>
            <div class="card-body p-0">
                @if (bySales.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>الموظف</th>
                                <th>الصفقات</th>
                                <th>الإيراد</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                                string[] medals = { "🥇", "🥈", "🥉" };
                            }
                            @foreach (var row in bySales)
                            {
                                string medal = rank <= 3 ? medals[rank - 1] : $"#{rank}";
                                string salesTotalText = ((decimal)row.Total).ToString("N0");
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span style="font-size:16px;">@medal</span>
                                            <span style="font-weight:600;">@row.SalesName</span>
                                        </div>
                                    </td>
                                    <td style="text-align:center;font-weight:700;">@row.Count</td>
                                    <td style="font-weight:800;color:#2563eb;">@salesTotalText ج.م</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state" style="padding:32px;">
                        <div class="empty-state-icon" style="font-size:2rem;">🏅</div>
                        <div class="empty-state-title">لا توجد بيانات مبيعات</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Salary details ── *@
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <span class="card-title">💵 تفاصيل المرتبات المصروفة</span>
            </div>
            <div class="card-body p-0">
                @if (salaryDetails.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>الموظف</th>
                                <th>الدور</th>
                                <th>الأساسي</th>
                                <th>مكافأة/خصم</th>
                                <th>الإجمالي</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in salaryDetails)
                            {
                                byte roleId = (byte)row.Role;
                                string roleName = roleId >= 1 && roleId < roleNames.Length ? roleNames[roleId] : "موظف";
                                decimal adj = (decimal)row.Adjustment;
                                string adjColor = adj >= 0 ? "#16a34a" : "#dc2626";
                                string adjSign = adj >= 0 ? "+" : "";
                                string baseSalaryText = ((decimal)row.BaseSalary).ToString("N0");
                                string adjustmentText = adj != 0 ? $"{adjSign}{adj:N0} ج.م" : "—";
                                string totalText = ((decimal)row.Total).ToString("N0");

                                <tr>
                                    <td style="font-weight:600;">@row.FullName</td>
                                    <td style="font-size:.78rem;color:var(--text-muted);">@roleName</td>
                                    <td>@baseSalaryText ج.م</td>
                                    <td style="color:@adjColor;font-weight:600;">
                                        @if (adj != 0)
                                        {
                                            @adjustmentText
                                        }
                                        else
                                        {
                                            <span style="color:var(--text-muted);">—</span>
                                        }
                                    </td>
                                    <td style="font-weight:800;color:#7c3aed;">@totalText ج.م</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f8fafc;font-weight:800;">
                                <td colspan="4">الإجمالي</td>
                                <td style="color:#7c3aed;">@salariesText ج.م</td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="empty-state" style="padding:32px;">
                        <div class="empty-state-icon" style="font-size:2rem;">💵</div>
                        <div class="empty-state-title">لا توجد مرتبات مصروفة هذا الشهر</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Financial summary ── *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <span class="card-title">📋 ملخص مالي — @months[month] @year</span>
            </div>
            <div class="card-body">
                @* Income *@
                <div style="margin-bottom:14px;">
                    <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">الإيرادات</div>
                    <div style="display:flex;justify-content:space-between;padding:10px 14px;background:#f0fdf4;border-radius:8px;">
                        <span style="font-size:13px;">💰 إجمالي المحصّل</span>
                        <span style="font-weight:800;color:#16a34a;">+ @totalCollectedText ج.م</span>
                    </div>
                </div>

                @* Expenses *@
                <div style="margin-bottom:14px;">
                    <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">المصروفات</div>
                    <div style="display:flex;justify-content:space-between;padding:10px 14px;background:#fef2f2;border-radius:8px;margin-bottom:6px;">
                        <span style="font-size:13px;">↩️ مردودات منفّذة</span>
                        <span style="font-weight:700;color:#dc2626;">- @refundsText ج.م</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:10px 14px;background:#fffbeb;border-radius:8px;margin-bottom:6px;">
                        <span style="font-size:13px;">🏆 عمولات مصروفة</span>
                        <span style="font-weight:700;color:#b45309;">- @commissionsText ج.م</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:10px 14px;background:#f5f3ff;border-radius:8px;margin-bottom:6px;">
                        <span style="font-size:13px;">💵 مرتبات مصروفة</span>
                        <span style="font-weight:700;color:#7c3aed;">- @salariesText ج.م</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 14px;border-top:1px dashed #e2e8f0;margin-top:4px;">
                        <span style="font-size:12px;color:var(--text-muted);">إجمالي المصروفات</span>
                        <span style="font-weight:700;color:#dc2626;">- @totalExpensesText ج.م</span>
                    </div>
                </div>

                @* Net profit *@
                <div style="display:flex;justify-content:space-between;align-items:center;
                            padding:14px 16px;border-radius:10px;
                            background:@profitBg;
                            border:2px solid @profitBorder;">
                    <span style="font-size:14px;font-weight:700;color:@profitText;">
                        📈 صافي الربح
                    </span>
                    <span style="font-size:20px;font-weight:800;color:@profitBorder;">
                        @netRevenueText ج.م
                    </span>
                </div>
            </div>
        </div>
    </div>

</div>