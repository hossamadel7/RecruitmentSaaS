@model List<RecruitmentSaaS.Controllers.SalaryUserDto>
@{
    ViewData["Title"] = "صرف المرتبات";
    int     selMonth     = (int)ViewBag.SelectedMonth;
    int     selYear      = (int)ViewBag.SelectedYear;
    decimal totalPayroll = (decimal)ViewBag.TotalPayroll;
    var     monthName    = new DateTime(selYear, selMonth, 1).ToString("MMMM yyyy");
    var     prev         = new DateTime(selYear, selMonth, 1).AddMonths(-1);
    var     next         = new DateTime(selYear, selMonth, 1).AddMonths(1);
}

<div style="padding:24px">

    @* ── Alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" style="font-size:13px">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" style="font-size:13px">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Header ── *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="page-header-title">صرف المرتبات</h1>
            <div class="page-header-sub">المرتبات المعتمدة من الأدمن — جاهزة للصرف</div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a href="/Accountant/Salaries?month=@prev.Month&year=@prev.Year"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-chevron-right"></i>
            </a>
            <span style="font-weight:700;font-size:15px;min-width:140px;text-align:center">
                @monthName
            </span>
            <a href="/Accountant/Salaries?month=@next.Month&year=@next.Year"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-chevron-left"></i>
            </a>
        </div>
    </div>

    @* ── Summary ── *@
    <div class="card mb-4" style="background:#EFF6FF;border:1px solid #BFDBFE">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-wallet2-fill text-primary" style="font-size:24px"></i>
                    <div>
                        <div style="font-size:12px;color:#2563EB;font-weight:600">
                            إجمالي المرتبات المعتمدة هذا الشهر
                        </div>
                        <div style="font-size:22px;font-weight:700;color:#1B4FD8">
                            @totalPayroll.ToString("N0") ج.م
                        </div>
                    </div>
                </div>
                <div style="font-size:13px;color:#2563EB">
                    <i class="bi bi-people-fill me-1"></i>
                    @Model.Count موظف في انتظار الصرف
                </div>
            </div>
        </div>
    </div>

    @* ── Table ── *@
    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-check-circle" style="font-size:40px;color:#CBD5E1"></i>
                <p class="mt-3 mb-1" style="font-weight:600;color:var(--text-muted)">
                    لا توجد مرتبات معتمدة لهذا الشهر
                </p>
                <p style="font-size:12.5px;color:var(--text-muted)">
                    انتظر موافقة الأدمن على مرتبات الموظفين أولاً
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header" style="padding:16px 20px">
                <span style="font-weight:600;font-size:14px">
                    <i class="bi bi-cash-coin me-2 text-primary"></i>
                    مرتبات جاهزة للصرف — @monthName
                    <span class="badge bg-primary ms-2">@Model.Count</span>
                </span>
            </div>
            <div style="overflow-x:auto">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>الموظف</th>
                            <th>الوظيفة</th>
                            <th>المرتب الأساسي</th>
                            <th>مكافأة / خصم</th>
                            <th>الإجمالي</th>
                            <th style="width:150px">الإجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;font-size:13.5px">@u.FullName</div>
                                    <div style="font-size:11.5px;color:var(--text-muted)">@u.Email</div>
                                </td>
                                <td>
                                    <span style="font-size:12px;font-weight:600;padding:3px 10px;
                                                 border-radius:20px;background:#EEF2FF;color:#1B4FD8">
                                        @u.RoleName
                                    </span>
                                </td>
                                <td>
                                    <span style="font-weight:600">@u.BaseSalary.ToString("N0")</span>
                                    <span style="font-size:11px;color:var(--text-muted)"> ج.م</span>
                                </td>
                                <td>
                                    @if (u.Adjustment != 0)
                                    {
                                        <span style="font-weight:700;color:@(u.Adjustment > 0 ? "#16A34A" : "#DC2626")">
                                            @(u.Adjustment > 0 ? "+" : "")@u.Adjustment.ToString("N0") ج.م
                                        </span>
                                        if (!string.IsNullOrEmpty(u.AdjustmentNote))
                                        {
                                            <div style="font-size:11px;color:var(--text-muted)">@u.AdjustmentNote</div>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted);font-size:12px">—</span>
                                    }
                                </td>
                                <td>
                                    <span style="font-weight:700;font-size:16px;color:#1B4FD8">
                                        @u.TotalAmount.ToString("N0")
                                    </span>
                                    <span style="font-size:11px;color:var(--text-muted)"> ج.م</span>
                                </td>
                                <td>
                                    <form asp-action="FulfillSalary" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="paymentId" value="@u.PaymentId" />
                                        <input type="hidden" name="month"     value="@selMonth"     />
                                        <input type="hidden" name="year"      value="@selYear"      />
                                        <button type="submit"
                                                class="btn btn-success btn-sm"
                                                style="font-size:12px;padding:5px 14px"
                                                onclick="return confirm('تأكيد صرف مرتب @u.FullName — @u.TotalAmount.ToString("N0") ج.م؟')">
                                            <i class="bi bi-cash-coin me-1"></i>
                                            تم الصرف
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" style="font-weight:700;font-size:13px">الإجمالي</td>
                            <td style="font-weight:700;font-size:15px;color:#1B4FD8">
                                @totalPayroll.ToString("N0") ج.م
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>
