@using RecruitmentSaaS.Models.Entities
@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int totalLeads = ViewBag.TotalLeads;
    int totalCandidates = ViewBag.TotalCandidates;
    int totalUsers = ViewBag.TotalUsers;
    int activeCampaigns = ViewBag.ActiveCampaigns;
    int pendingRefunds = ViewBag.PendingRefunds;
    int pendingCommissions = ViewBag.PendingCommissions;
    int pendingPayments = ViewBag.PendingPayments;
    decimal totalCollected = ViewBag.TotalCollected;

    var recentLeads = (IEnumerable<Lead>)ViewBag.RecentLeads;
    var leadsByStatus = (IEnumerable<dynamic>)ViewBag.LeadsByStatus;
    var candidatesByStage = (IEnumerable<dynamic>)ViewBag.CandidatesByStage;

    string[] leadStatusLabels = { "", "عميل جديد", "تم التواصل", "مهتم", "يفكر", "وعد بالزيارة", "زيارة", "تحويل", "ملغى" };
    string[] leadStatusColors = { "", "#3b82f6", "#8b5cf6", "#0ea5e9", "#f59e0b", "#22c55e", "#ec4899", "#6366f1", "#dc2626" };

    string[] stageLabels = { "", "توثيق المستندات", "تجهيز الملف", "الكشف الطبي", "معالجة التأشيرة", "حجز التذاكر", "التجهيز للسفر", "مكتمل" };
    string[] stageColors = { "", "#3b82f6", "#8b5cf6", "#0ea5e9", "#f59e0b", "#ec4899", "#6366f1", "#22c55e" };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);">🛡️</div>
        <div>
            <h1 class="page-title">لوحة التحكم</h1>
            <p style="color:var(--text-muted);font-size:.8rem;margin:2px 0 0;">نظرة عامة على النظام</p>
        </div>
    </div>
</div>

@* Pending alerts *@
@if (pendingRefunds > 0 || pendingCommissions > 0)
{
    <div class="d-flex gap-3 mb-4 flex-wrap">
        @if (pendingRefunds > 0)
        {
            <a href="/Admin/Refunds" class="alert-pill" style="background:#fef2f2;border:1.5px solid #fecaca;color:#dc2626;padding:10px 18px;border-radius:10px;font-size:.82rem;font-weight:700;text-decoration:none;display:flex;align-items:center;gap:8px;">
                ↩️ <span>@pendingRefunds طلب استرداد في انتظار موافقتك</span>
                <span style="background:#dc2626;color:#fff;border-radius:99px;padding:2px 8px;font-size:.72rem;">جديد</span>
            </a>
        }
        @if (pendingCommissions > 0)
        {
            <a href="/Admin/Commissions" class="alert-pill" style="background:#fffbeb;border:1.5px solid #fde68a;color:#b45309;padding:10px 18px;border-radius:10px;font-size:.82rem;font-weight:700;text-decoration:none;display:flex;align-items:center;gap:8px;">
                🏆 <span>@pendingCommissions عمولة في انتظار اعتمادك</span>
                <span style="background:#b45309;color:#fff;border-radius:99px;padding:2px 8px;font-size:.72rem;">جديد</span>
            </a>
        }
    </div>
}

@* KPI cards *@
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff;color:#2563eb;">👥</div>
            <div>
                <div class="stat-value">@totalLeads.ToString("N0")</div>
                <div class="stat-label">إجمالي العملاء المحتملين</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0fdf4;color:#16a34a;">🧳</div>
            <div>
                <div class="stat-value">@totalCandidates.ToString("N0")</div>
                <div class="stat-label">إجمالي المرشحين</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fffbeb;color:#b45309;">💰</div>
            <div>
                <div class="stat-value">@totalCollected.ToString("N0")</div>
                <div class="stat-label">إجمالي المحصّل (ج.م)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#faf5ff;color:#7c3aed;">📣</div>
            <div>
                <div class="stat-value">@activeCampaigns</div>
                <div class="stat-label">حملات نشطة</div>
            </div>
        </div>
    </div>
</div>

@* Secondary stats — pending actions *@
<div class="row g-3 mb-4">
    <div class="col-md-4 col-6">
        <a href="/Admin/Refunds" class="text-decoration-none">
            <div class="stat-card" style="border-right: 3px solid #dc2626;">
                <div class="stat-icon" style="background:#fef2f2;color:#dc2626;">↩️</div>
                <div>
                    <div class="stat-value" style="color:#dc2626;">@pendingRefunds</div>
                    <div class="stat-label">استردادات معلقة</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a href="/Admin/Commissions" class="text-decoration-none">
            <div class="stat-card" style="border-right: 3px solid #b45309;">
                <div class="stat-icon" style="background:#fffbeb;color:#b45309;">🏆</div>
                <div>
                    <div class="stat-value" style="color:#b45309;">@pendingCommissions</div>
                    <div class="stat-label">عمولات تحتاج اعتماد</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a href="/Admin/Users" class="text-decoration-none">
            <div class="stat-card" style="border-right: 3px solid #2563eb;">
                <div class="stat-icon" style="background:#eff6ff;color:#2563eb;">👤</div>
                <div>
                    <div class="stat-value" style="color:#2563eb;">@totalUsers</div>
                    <div class="stat-label">مستخدمي النظام</div>
                </div>
            </div>
        </a>
    </div>
</div>

@* Charts row *@
<div class="row g-3 mb-4">
    @* Leads by status *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <span class="card-title">📊 العملاء المحتملين حسب الحالة</span>
                <a href="/Admin/Leads" class="btn btn-ghost btn-sm">عرض الكل</a>
            </div>
            <div class="card-body">
                @if (leadsByStatus != null && leadsByStatus.Any())
                {
                    @foreach (var item in leadsByStatus)
                    {
                        int s = (int)item.Status;
                        int count = (int)item.Count;
                        string label = s >= 1 && s < leadStatusLabels.Length ? leadStatusLabels[s] : $"حالة {s}";
                        string color = s >= 1 && s < leadStatusColors.Length ? leadStatusColors[s] : "#64748b";
                        double pct = totalLeads > 0 ? (count * 100.0 / totalLeads) : 0;

                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="font-size:.78rem;font-weight:600;color:@color;">@label</span>
                                <span style="font-size:.78rem;color:var(--text-muted);">@count</span>
                            </div>
                            <div style="height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
                                <div style="height:100%;width:@(pct.ToString("F1"))%;background:@color;border-radius:3px;transition:width .4s;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:24px;">
                        <div class="empty-state-icon">📊</div>
                        <div class="empty-state-title">لا يوجد بيانات</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Candidates by stage *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <span class="card-title">🧳 المرشحون حسب المرحلة</span>
                <a href="/Admin/Candidates" class="btn btn-ghost btn-sm">عرض الكل</a>
            </div>
            <div class="card-body">
                @if (candidatesByStage != null && candidatesByStage.Any())
                {
                    @foreach (var item in candidatesByStage)
                    {
                        int s = (int)item.Stage;
                        int count = (int)item.Count;
                        string label = s >= 1 && s < stageLabels.Length ? stageLabels[s] : $"مرحلة {s}";
                        string color = s >= 1 && s < stageColors.Length ? stageColors[s] : "#64748b";
                        double pct = totalCandidates > 0 ? (count * 100.0 / totalCandidates) : 0;

                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="font-size:.78rem;font-weight:600;color:@color;">@label</span>
                                <span style="font-size:.78rem;color:var(--text-muted);">@count</span>
                            </div>
                            <div style="height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
                                <div style="height:100%;width:@(pct.ToString("F1"))%;background:@color;border-radius:3px;transition:width .4s;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:24px;">
                        <div class="empty-state-icon">🧳</div>
                        <div class="empty-state-title">لا يوجد مرشحون</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Recent Leads *@
<div class="card">
    <div class="card-header">
        <span class="card-title">🕐 أحدث العملاء المحتملين</span>
        <a href="/Admin/Leads" class="btn btn-ghost btn-sm">عرض الكل</a>
    </div>
    <div class="card-body p-0">
        @if (recentLeads != null && recentLeads.Any())
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الهاتف</th>
                        <th>الحملة</th>
                        <th>المسؤول</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in recentLeads)
                    {
                        int s = lead.Status;
                        string label = s >= 1 && s < leadStatusLabels.Length ? leadStatusLabels[s] : $"حالة {s}";
                        string color = s >= 1 && s < leadStatusColors.Length ? leadStatusColors[s] : "#64748b";
                        string colorBg = color + "20";
                        string colorBorder = color + "40";

                        <tr>
                            <td style="font-weight:600;">@lead.FullName</td>
                            <td style="font-family:monospace;font-size:.83rem;">@lead.Phone</td>
                            <td style="font-size:.82rem;color:var(--text-muted);">@(lead.Campaign?.Name ?? "—")</td>
                            <td style="font-size:.82rem;">@(lead.AssignedSales?.FullName ?? "—")</td>
                            <td>
                                <span style="background:@colorBg;color:@color;border:1px solid @colorBorder;font-size:.7rem;padding:3px 8px;border-radius:99px;font-weight:700;">
                                    @label
                                </span>
                            </td>
                            <td style="font-size:.78rem;color:var(--text-muted);">
                                @lead.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state" style="padding:32px;">
                <div class="empty-state-icon">👥</div>
                <div class="empty-state-title">لا يوجد عملاء محتملين بعد</div>
            </div>
        }
    </div>
</div>
