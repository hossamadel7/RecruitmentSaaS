                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="History"?"active":"")" href="/Accountant/History">
                        <span class="nav-icon"><i class="bi bi-clock-history"></i></span> سجل المعاملات
                    </a>
                </div>
                <div class="sidebar-section">المرشحون</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="AllCandidates"?"active":"")" href="/Accountant/AllCandidates">
                        <span class="nav-icon"><i class="bi bi-people-fill"></i></span> ملخص مالي للمرشحين
                    </a>
                </div>
                <div class="sidebar-section">المالية</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="Refunds"?"active":"")" href="/Accountant/Refunds">
                        <span class="nav-icon"><i class="bi bi-arrow-counterclockwise"></i></span> الاستردادات
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="Commissions"?"active":"")" href="/Accountant/Commissions">
                        <span class="nav-icon"><i class="bi bi-cash-stack"></i></span> العمولات
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="Salaries"?"active":"")" href="/Accountant/Salaries">
                        <span class="nav-icon"><i class="bi bi-cash-coin"></i></span> صرف المرتبات
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Accountant"&&currentAction=="Reports"?"active":"")" href="/Accountant/Reports">
                        <span class="nav-icon"><i class="bi bi-bar-chart-fill"></i></span> التقارير
                    </a>
                </div>
            }

            @* ── OPERATIONS (Role 5) ── *@
            @if (role == "5")
            {
                <div class="sidebar-section">الرئيسية</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Operations"&&currentAction=="Index"?"active":"")" href="/Operations/Index">
                        <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span> لوحة العمليات
                    </a>
                </div>
                <div class="sidebar-section">المرشحين</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Operations"&&currentAction=="Candidates"?"active":"")" href="/Operations/Candidates">
                        <span class="nav-icon"><i class="bi bi-people-fill"></i></span> المرشحين
                    </a>
                </div>
            }

            @* ── OFFICE SALES (Role 6) ── *@
            @if (role == "6")
            {
                <div class="sidebar-section">الرئيسية</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Sales"&&currentAction=="Index"?"active":"")" href="/Sales/Index">
                        <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span> لوحة المبيعات
                    </a>
                </div>
                <div class="sidebar-section">العمل</div>
                <div class="nav-item">
                    <a class="nav-link @(currentController=="Sales"&&currentAction=="Candidates"?"active":"")" href="/Sales/Candidates">
                        <span class="nav-icon"><i class="bi bi-people-fill"></i></span> المرشحين
                    </a>
                </div>
