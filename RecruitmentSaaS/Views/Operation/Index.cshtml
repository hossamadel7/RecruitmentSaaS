@{
    ViewData["Title"] = "لوحة العمليات";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int total = ViewBag.TotalCandidates;
    int inProgress = ViewBag.InProgress;
    int completed = ViewBag.CompletedCount;
    var byStage = (IEnumerable<dynamic>)ViewBag.ByStage;

    string[] stageLabels = { "", "توثيق المستندات", "تجهيز الملف", "الكشف الطبي",
                              "معالجة التأشيرة", "حجز التذاكر", "التجهيز للسفر", "مكتمل - سافر" };
    string[] stageIcons = { "", "📄", "📁", "🏥", "🛂", "✈️", "🧳", "✅" };
    string[] stageColors = { "", "#3b82f6", "#8b5cf6", "#0ea5e9", "#f59e0b", "#ec4899", "#6366f1", "#22c55e" };
}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">⚙️</div>
        <div>
            <h1 class="page-title">لوحة العمليات</h1>
            <p style="color:var(--text-muted);font-size:.8rem;margin:2px 0 0;">
                متابعة مراحل المرشحين
            </p>
        </div>
    </div>
    <a href="/Operations/Candidates" class="btn btn-primary">
        <i class="bi bi-people-fill me-1"></i> عرض كل المرشحين
    </a>
</div>

@* Stats *@
<div class="row g-3 mb-4">
    <div class="col-md-4 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff;color:#2563eb;">👥</div>
            <div>
                <div class="stat-value">@total</div>
                <div class="stat-label">إجمالي المرشحين</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fffbeb;color:#b45309;">⏳</div>
            <div>
                <div class="stat-value">@inProgress</div>
                <div class="stat-label">قيد المعالجة</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0fdf4;color:#16a34a;">✅</div>
            <div>
                <div class="stat-value">@completed</div>
                <div class="stat-label">مكتملون / سافروا</div>
            </div>
        </div>
    </div>
</div>

@* Pipeline by stage *@
<div class="card">
    <div class="card-header">
        <span class="card-title">📊 توزيع المرشحين على المراحل</span>
        <a href="/Operations/Candidates" class="btn btn-ghost btn-sm">عرض الكل</a>
    </div>
    <div class="card-body">
        @if (byStage != null && byStage.Any())
        {
            <div class="row g-3">
                @foreach (var item in byStage)
                {
                    int s = (int)item.Stage;
                    int count = (int)item.Count;
                    string label = s >= 1 && s < stageLabels.Length ? stageLabels[s] : $"مرحلة {s}";
                    string icon = s >= 1 && s < stageIcons.Length ? stageIcons[s] : "📌";
                    string color = s >= 1 && s < stageColors.Length ? stageColors[s] : "#64748b";

                    <div class="col-md-3 col-6">
                        <a href="/Operations/Candidates?stage=@s" class="text-decoration-none">
                            <div class="card card-flat" style="border-right:4px solid @color;padding:16px;transition:transform .15s;"
                                 onmouseover="this.style.transform='translateY(-2px)'"
                                 onmouseout="this.style.transform=''">
                                <div style="font-size:1.6rem;margin-bottom:6px;">@icon</div>
                                <div style="font-size:1.4rem;font-weight:800;color:@color;">@count</div>
                                <div style="font-size:.75rem;color:var(--text-muted);margin-top:2px;">@label</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state" style="padding:32px;">
                <div class="empty-state-icon">👥</div>
                <div class="empty-state-title">لا يوجد مرشحون قيد المعالجة</div>
            </div>
        }
    </div>
</div>
