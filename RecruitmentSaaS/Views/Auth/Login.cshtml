@model RecruitmentSaaS.Models.DTOs.LoginDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول — الفهد العربي</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@@300;400;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --gold: #C9A84C;
            --gold-lt: #F0D080;
            --dark: #080E1E;
            --dark2: #0D1829;
            --blue: #1B4FD8;
            --blue-dk: #1340B0;
            --white: #ffffff;
            --muted: rgba(255,255,255,.45);
            --border: rgba(255,255,255,.1);
        }

        html, body {
            height: 100%;
            font-family: 'Cairo', sans-serif;
            overflow: hidden;
        }

        /* ── Split Layout ── */
        .page {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* ── Left Panel — Branding ── */
        .panel-left {
            flex: 1.1;
            background: var(--dark);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px;
            overflow: hidden;
        }

            /* Grid texture */
            .panel-left::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
                background-size: 44px 44px;
                pointer-events: none;
            }

        /* Gold orb */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
        }

        .orb-1 {
            width: 480px;
            height: 480px;
            background: radial-gradient(circle, rgba(201,168,76,.22), transparent 70%);
            top: -120px;
            left: -120px;
            animation: orbFloat 9s ease-in-out infinite;
        }

        .orb-2 {
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(27,79,216,.18), transparent 70%);
            bottom: -80px;
            right: -60px;
            animation: orbFloat 12s ease-in-out infinite reverse;
        }
        @@keyframes orbFloat {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        50% {
            transform: translate(24px,-24px) scale(1.06);
        }

        }

        .panel-left-inner {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        /* Logo */
        .logo-wrap {
            width: 160px;
            height: 160px;
            margin: 0 auto 28px;
            border-radius: 28px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(201,168,76,.25);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: 0 0 60px rgba(201,168,76,.18);
            animation: logoIn .8s cubic-bezier(.22,1,.36,1) both;
        }

            .logo-wrap img {
                width: 130px;
                height: 130px;
                object-fit: contain;
                filter: drop-shadow(0 4px 16px rgba(201,168,76,.35));
            }

        @@keyframes logoIn {
            from

        {
            opacity: 0;
            transform: scale(.8) translateY(20px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }

        }

        .brand-name {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--white);
            line-height: 1.15;
            animation: fadeUp .8s .1s both;
        }

            .brand-name span {
                background: linear-gradient(90deg, var(--gold), var(--gold-lt), var(--gold));
                background-size: 200%;
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                animation: shimmer 3s infinite linear;
            }
        @@keyframes shimmer {
            0%

        {
            background-position: 0%;
        }

        100% {
            background-position: 200%;
        }

        }

        .brand-sub {
            font-size: .9rem;
            color: var(--muted);
            margin-top: 8px;
            font-weight: 400;
            animation: fadeUp .8s .2s both;
        }

        /* Stats strip */
        .stats-strip {
            display: flex;
            gap: 0;
            margin-top: 48px;
            border-top: 1px solid var(--border);
            animation: fadeUp .8s .3s both;
        }

        .stat {
            flex: 1;
            padding: 20px 16px;
            border-left: 1px solid var(--border);
            text-align: center;
        }

            .stat:last-child {
                border-left: none;
            }

        .stat-num {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--gold);
            line-height: 1;
        }

        .stat-lbl {
            font-size: .68rem;
            color: var(--muted);
            margin-top: 4px;
        }

        /* Trust badges */
        .badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 32px;
            animation: fadeUp .8s .4s both;
        }

        .badge-item {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,.05);
            border: 1px solid var(--border);
            border-radius: 99px;
            padding: 5px 14px;
            font-size: .72rem;
            color: rgba(255,255,255,.65);
            font-weight: 600;
        }

            .badge-item i {
                color: var(--gold);
                font-size: .85rem;
            }

        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ── Right Panel — Form ── */
        .panel-right {
            width: 460px;
            flex-shrink: 0;
            background: var(--dark2);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 40px;
            position: relative;
            border-right: 1px solid var(--border);
        }

            .panel-right::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(27,79,216,.08), transparent 60%);
                pointer-events: none;
            }

        .form-wrap {
            width: 100%;
            position: relative;
            z-index: 1;
            animation: fadeUp .7s .15s both;
        }

        .form-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--white);
            margin-bottom: 6px;
        }

        .form-sub {
            font-size: .82rem;
            color: var(--muted);
            margin-bottom: 32px;
        }

        /* Field */
        .field {
            margin-bottom: 20px;
        }

            .field label {
                display: block;
                font-size: .82rem;
                font-weight: 700;
                color: rgba(255,255,255,.75);
                margin-bottom: 7px;
            }

        .field-wrap {
            position: relative;
        }

            .field-wrap .f-icon {
                position: absolute;
                top: 50%;
                right: 14px;
                transform: translateY(-50%);
                color: rgba(255,255,255,.3);
                font-size: .95rem;
                pointer-events: none;
                transition: color .25s;
            }

            .field-wrap .pw-toggle {
                position: absolute;
                top: 50%;
                left: 14px;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: rgba(255,255,255,.3);
                font-size: .95rem;
                cursor: pointer;
                transition: color .25s;
                padding: 0;
            }

            .field-wrap:focus-within .f-icon,
            .pw-toggle:hover {
                color: var(--gold);
            }

        .field input {
            width: 100%;
            padding: 13px 42px 13px 42px;
            background: rgba(255,255,255,.06);
            border: 1.5px solid rgba(255,255,255,.12);
            border-radius: 12px;
            color: var(--white);
            font-size: .9rem;
            font-family: 'Cairo', sans-serif;
            outline: none;
            transition: border-color .25s, background .25s, box-shadow .25s;
        }

            .field input::placeholder {
                color: rgba(255,255,255,.25);
            }

            .field input:focus {
                border-color: var(--gold);
                background: rgba(255,255,255,.09);
                box-shadow: 0 0 0 3px rgba(201,168,76,.15);
            }

        /* Error */
        .error-box {
            background: rgba(239,68,68,.12);
            border: 1px solid rgba(239,68,68,.3);
            border-radius: 10px;
            color: #fca5a5;
            font-size: .82rem;
            padding: 10px 14px;
            margin-bottom: 20px;
        }

        .val-msg {
            color: #fca5a5;
            font-size: .75rem;
            margin-top: 4px;
            display: block;
        }

        /* Button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--gold), #B8922E);
            border: none;
            border-radius: 12px;
            color: var(--dark);
            font-size: 1rem;
            font-weight: 800;
            font-family: 'Cairo', sans-serif;
            cursor: pointer;
            transition: transform .2s, box-shadow .25s, filter .25s;
            box-shadow: 0 6px 24px rgba(201,168,76,.35);
            margin-top: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-login:hover {
                filter: brightness(1.08);
                transform: translateY(-2px);
                box-shadow: 0 10px 32px rgba(201,168,76,.5);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 28px 0 20px;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .divider-text {
            font-size: .72rem;
            color: var(--muted);
            white-space: nowrap;
        }

        /* Footer */
        .form-footer {
            text-align: center;
            font-size: .74rem;
            color: var(--muted);
            margin-top: 28px;
        }

        /* Responsive */
       @@media (max-width: 768px) {
            .panel-left

        {
            display: none;
        }

        .panel-right {
            width: 100%;
            padding: 32px 24px;
        }

        }
    </style>
</head>
<body>
    <div class="page">

        <!-- ── Left: Branding ── -->
        <div class="panel-left">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="panel-left-inner">
                <div class="logo-wrap">
                    <img src="/uploads/images/logo fahd.png" alt="الفهد العربي" />
                </div>
                <div class="brand-name">
                    <span>الفهد العربي</span>
                </div>
                <div class="brand-sub">منصة إدارة التوظيف الدولي الذكية</div>

                <div class="stats-strip">
                    <div class="stat">
                        <div class="stat-num">+5K</div>
                        <div class="stat-lbl">موظف مُشغَّل</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">12</div>
                        <div class="stat-lbl">دولة</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">15+</div>
                        <div class="stat-lbl">سنة خبرة</div>
                    </div>
                </div>

                <div class="badges">
                    <div class="badge-item"><i class="bi bi-patch-check-fill"></i> شركة مرخصة</div>
                    <div class="badge-item"><i class="bi bi-shield-fill-check"></i> عقود موثقة</div>
                    <div class="badge-item"><i class="bi bi-headset"></i> دعم ٢٤/٧</div>
                </div>
            </div>
        </div>

        <!-- ── Right: Form ── -->
        <div class="panel-right">
            <div class="form-wrap">
                <div class="form-title">مرحباً بعودتك 👋</div>
                <div class="form-sub">سجّل الدخول للوصول إلى لوحة التحكم</div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-box">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>⚠️ @error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Login" method="post" id="loginForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <div class="field-wrap">
                            <input asp-for="Email"
                                   placeholder="example@domain.com"
                                   autocomplete="email"
                                   dir="ltr" />
                            <i class="bi bi-envelope f-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="val-msg"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Password">كلمة المرور</label>
                        <div class="field-wrap">
                            <input asp-for="Password"
                                   type="password"
                                   id="pwInput"
                                   placeholder="••••••••••"
                                   autocomplete="current-password" />
                            <i class="bi bi-lock f-icon"></i>
                            <button type="button" class="pw-toggle" onclick="togglePw()" aria-label="إظهار كلمة المرور">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="val-msg"></span>
                    </div>

                    <button type="submit" class="btn-login" id="submitBtn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        دخول إلى حسابي
                    </button>
                </form>

                <div class="divider">
                    <div class="divider-line"></div>
                    <div class="divider-text">نظام التوظيف الذكي</div>
                    <div class="divider-line"></div>
                </div>

                <div style="display:flex;gap:12px;text-align:center;">
                    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid var(--border);
                            border-radius:10px;padding:12px 8px;">
                        <i class="bi bi-people-fill" style="color:var(--gold);font-size:1.2rem;"></i>
                        <div style="font-size:.7rem;color:var(--muted);margin-top:4px;">إدارة المرشحين</div>
                    </div>
                    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid var(--border);
                            border-radius:10px;padding:12px 8px;">
                        <i class="bi bi-graph-up-arrow" style="color:var(--gold);font-size:1.2rem;"></i>
                        <div style="font-size:.7rem;color:var(--muted);margin-top:4px;">تقارير مالية</div>
                    </div>
                    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid var(--border);
                            border-radius:10px;padding:12px 8px;">
                        <i class="bi bi-globe-americas" style="color:var(--gold);font-size:1.2rem;"></i>
                        <div style="font-size:.7rem;color:var(--muted);margin-top:4px;">توظيف دولي</div>
                    </div>
                </div>

                <div class="form-footer">
                    &copy; @DateTime.Now.Year الفهد العربي للتوظيف الدولي — جميع الحقوق محفوظة
                </div>
            </div>
        </div>

    </div>

    <script>
        function togglePw() {
            const inp  = document.getElementById('pwInput');
            const icon = document.getElementById('eyeIcon');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                inp.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        // Disable button on submit
        document.getElementById('loginForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span style="display:inline-block;width:16px;height:16px;border:2px solid rgba(0,0,0,.3);border-top-color:#000;border-radius:50%;animation:spin .7s linear infinite;"></span> جارٍ الدخول...';
        });
    </script>
    <style>
        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }
    </style>
</body>
</html>
