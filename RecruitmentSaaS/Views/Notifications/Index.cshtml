@model List<RecruitmentSaaS.Models.Entities.Notification>
@{
    ViewData["Title"] = "الإشعارات";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string TypeIcon(byte t) => t switch {
        1 => "bi-shield-lock-fill",
        2 => "bi-arrow-left-circle-fill",
        3 => "bi-cash-coin",
        4 => "bi-arrow-counterclockwise",
        5 => "bi-cash-stack",
        _ => "bi-bell-fill"
    };
    string TypeColor(byte t) => t switch {
        1 => "#7c3aed",
        2 => "var(--primary)",
        3 => "#16a34a",
        4 => "#f59e0b",
        5 => "#0ea5e9",
        _ => "#64748b"
    };
    string TypeBg(byte t) => t switch {
        1 => "#f5f3ff",
        2 => "var(--primary-light)",
        3 => "#f0fdf4",
        4 => "#fffbeb",
        5 => "#f0f9ff",
        _ => "#f8fafc"
    };
}

<div style="padding:24px;max-width:720px;margin:0 auto">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
        <div>
            <h1 style="font-size:22px;font-weight:800;margin:0">🔔 الإشعارات</h1>
            <p style="font-size:13px;color:var(--text-muted);margin:4px 0 0">آخر 50 إشعار</p>
        </div>
        @if (Model.Any(n => n.IsRead == false))
        {
            <form method="post" action="/Notifications/MarkAllRead">
                @Html.AntiForgeryToken()
                <button type="submit"
                        style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 14px;font-size:13px;cursor:pointer;font-family:inherit;color:var(--text-muted)">
                    <i class="bi bi-check-all me-1"></i> تعيين الكل كمقروء
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div style="background:var(--card-bg);border-radius:var(--radius);border:2px dashed var(--border);padding:60px;text-align:center">
            <div style="font-size:48px;margin-bottom:12px">🔔</div>
            <div style="font-weight:700;font-size:15px;color:var(--text-muted)">لا توجد إشعارات بعد</div>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:8px">
        @foreach (var n in Model)
        {
            var isUnread = n.IsRead == false;
            <a href="@(n.Link ?? "#")"
               style="display:flex;gap:14px;align-items:flex-start;padding:14px 18px;background:@(isUnread ? "var(--card-bg)" : "#fafafa");border-radius:var(--radius);border:1px solid @(isUnread ? "var(--primary)" : "var(--border)");text-decoration:none;color:inherit;transition:all .15s">

                <!-- Icon -->
                <div style="width:38px;height:38px;border-radius:50%;background:@TypeBg(n.Type);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                    <i class="bi @TypeIcon(n.Type)" style="font-size:15px;color:@TypeColor(n.Type)"></i>
                </div>

                <!-- Content -->
                <div style="flex:1;min-width:0">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px">
                        <span style="font-weight:@(isUnread ? "700" : "600");font-size:13px;color:var(--text-primary)">
                            @n.Title
                        </span>
                        @if (isUnread)
                        {
                            <span style="width:7px;height:7px;border-radius:50%;background:var(--primary);flex-shrink:0;display:inline-block"></span>
                        }
                    </div>
                    <div style="font-size:12px;color:var(--text-muted);line-height:1.5">@n.Body</div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
                        @n.CreatedAt.ToString("dd/MM/yyyy — HH:mm")
                    </div>
                </div>
            </a>
        }
        </div>
    }
</div>
