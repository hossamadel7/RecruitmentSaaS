@{
    ViewData["Title"] = "تفاصيل الشركة";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var company = ViewBag.Company as RecruitmentSaaS.Models.Entities.Company;
    int assigned = (int)(ViewBag.AssignedCount ?? 0);
    int completed = (int)(ViewBag.CompletedCount ?? 0);
    int remaining = (int)(ViewBag.RemainingCount ?? 0);
    int requested = (int)(ViewBag.RequestedCount ?? 0);
    int fillPct = requested > 0 ? Math.Min(100, assigned * 100 / requested) : 0;
}

<div style="padding:24px;max-width:1100px">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" style="font-size:13px">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Back + Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
        <div style="display:flex;align-items:center;gap:12px">
            <a href="/Companies/Index" style="color:var(--text-muted);text-decoration:none;font-size:13px">
                <i class="bi bi-arrow-right me-1"></i> الشركات
            </a>
            <span style="color:var(--border)">/</span>
            <h1 style="font-size:20px;font-weight:800;margin:0">🏢 @company?.Name</h1>
            @if (company?.IsActive == true)
            {
                <span style="background:#f0fdf4;color:#16a34a;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600">● نشطة</span>
            }
            else
            {
                <span style="background:#f8fafc;color:var(--text-muted);padding:2px 10px;border-radius:20px;font-size:11px">غير نشطة</span>
            }
        </div>
        <button onclick="openAssignModal()"
                style="background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:9px 18px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
            <i class="bi bi-person-plus-fill me-2"></i> تعيين مرشح
        </button>
    </div>

    <!-- Company Info + Stats -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">

        <!-- Info Card -->
        <div style="background:var(--card-bg);border-radius:var(--radius);border:1px solid var(--border);padding:20px">
            <h2 style="font-size:14px;font-weight:700;margin:0 0 16px;color:var(--text-muted)">بيانات الشركة</h2>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px">
                <div>
                    <div style="color:var(--text-muted);font-size:11px;margin-bottom:2px">مكان العمل</div>
                    <div style="font-weight:600">
                        <span style="background:#eff6ff;color:#1d4ed8;padding:2px 10px;border-radius:20px;font-size:12px">@company?.Country</span>
                        @if (!string.IsNullOrEmpty(company?.City))
                        {
                            <span style="color:var(--text-muted);margin-right:4px">· @company.City</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(company?.ContactPhone))
                {
                    <div>
                        <div style="color:var(--text-muted);font-size:11px;margin-bottom:2px">التليفون</div>
                        <div style="font-weight:600;direction:ltr;text-align:right">@company.ContactPhone</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(company?.ContactEmail))
                {
                    <div>
                        <div style="color:var(--text-muted);font-size:11px;margin-bottom:2px">الإيميل</div>
                        <div style="font-weight:600;font-size:12px;direction:ltr;text-align:right">@company.ContactEmail</div>
                    </div>
                }
                @if (company?.ContractStartDate != null)
                {
                    <div>
                        <div style="color:var(--text-muted);font-size:11px;margin-bottom:2px">بداية العقد</div>
                        <div style="font-weight:600">@company.ContractStartDate.Value.ToString("dd/MM/yyyy")</div>
                    </div>
                }
                <div>
                    <div style="color:var(--text-muted);font-size:11px;margin-bottom:2px">أضيفت بواسطة</div>
                    <div style="font-weight:600;font-size:12px">@(company?.CreatedBy?.FullName ?? "—")</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(company?.Notes))
            {
                <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border)">
                    <div style="color:var(--text-muted);font-size:11px;margin-bottom:4px">ملاحظات</div>
                    <div style="font-size:12px;line-height:1.6">@company.Notes</div>
                </div>
            }
        </div>

        <!-- Stats Card -->
        <div style="background:var(--card-bg);border-radius:var(--radius);border:1px solid var(--border);padding:20px">
            <h2 style="font-size:14px;font-weight:700;margin:0 0 16px;color:var(--text-muted)">إحصائيات التوظيف</h2>

            <!-- Progress -->
            <div style="margin-bottom:20px">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                    <span style="font-size:13px;font-weight:600">نسبة التعبئة</span>
                    <span style="font-size:18px;font-weight:800;color:var(--primary)">@fillPct%</span>
                </div>
                <div style="background:#e2e8f0;border-radius:8px;height:10px">
                    <div style="background:@(fillPct >= 100 ? "#16a34a" : "var(--primary)");height:10px;border-radius:8px;width:@(fillPct)%;transition:width .5s"></div>
                </div>
            </div>

            <!-- 4 numbers -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div style="background:#f8fafc;border-radius:var(--radius-sm);padding:14px;text-align:center">
                    <div style="font-size:24px;font-weight:800">@requested</div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px">مطلوب</div>
                </div>
                <div style="background:#eff6ff;border-radius:var(--radius-sm);padding:14px;text-align:center">
                    <div style="font-size:24px;font-weight:800;color:var(--primary)">@assigned</div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px">تم التعيين</div>
                </div>
                <div style="background:#f0fdf4;border-radius:var(--radius-sm);padding:14px;text-align:center">
                    <div style="font-size:24px;font-weight:800;color:#16a34a">@completed</div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px">سافروا</div>
                </div>
                <div style="background:@(remaining > 0 ? "#fef9c3" : "#f0fdf4");border-radius:var(--radius-sm);padding:14px;text-align:center">
                    <div style="font-size:24px;font-weight:800;color:@(remaining > 0 ? "#854d0e" : "#16a34a")">
                        @(remaining > 0 ? remaining.ToString() : "✓")
                    </div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px">@(remaining > 0 ? "متبقي" : "مكتمل")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Jobs Section -->
    <div style="background:var(--card-bg);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;margin-bottom:20px">
        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <h2 style="font-size:14px;font-weight:700;margin:0">💼 المسميات الوظيفية</h2>
            <button onclick="document.getElementById('addJobModal').style.display='flex'"
                    style="background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit">
                <i class="bi bi-plus me-1"></i> إضافة مسمى
            </button>
        </div>
        @{
            var jobs = company?.CompanyJobs?.ToList() ?? new List<RecruitmentSaaS.Models.Entities.CompanyJob>();
        }
        @if (!jobs.Any())
        {
            <div style="padding:24px;text-align:center;font-size:13px;color:var(--text-muted)">
                لا توجد مسميات وظيفية — أضف أول مسمى
            </div>
        }
        else
        {
            <table class="table mb-0" style="font-size:13px">
                <thead style="background:#f8fafc">
                    <tr>
                        <th style="padding:10px 20px;font-weight:700;color:var(--text-muted);font-size:12px">المسمى الوظيفي</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px;text-align:center">المطلوب</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px;text-align:center">المُعيَّن</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px;text-align:center">المتبقي</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px">ملاحظات</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in jobs)
                    {
                        int jobAssigned = ViewBag.Candidates != null
                        ? 0  // will compute below
                        : 0;
                        <tr style="border-top:1px solid var(--border)">
                            <td style="padding:12px 20px;font-weight:700">@job.JobTitle</td>
                            <td style="padding:12px 20px;text-align:center;font-weight:700">@job.RequestedCount</td>
                            <td style="padding:12px 20px;text-align:center;color:var(--primary);font-weight:700">—</td>
                            <td style="padding:12px 20px;text-align:center">
                                <span style="background:#fef9c3;color:#854d0e;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700">
                                    @job.RequestedCount
                                </span>
                            </td>
                            <td style="padding:12px 20px;font-size:12px;color:var(--text-muted)">@(job.Notes ?? "—")</td>
                            <td style="padding:12px 20px;display:flex;gap:6px">
                                <button onclick="openEditJobModal('@job.Id','@Html.Raw(job.JobTitle)','@job.RequestedCount','@Html.Raw(job.Notes ?? "")')"
                                        style="background:#f1f5f9;border:none;border-radius:var(--radius-sm);padding:4px 10px;font-size:12px;cursor:pointer">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" action="/Companies/DeleteJob" style="display:inline"
                                      onsubmit="return confirm('حذف هذا المسمى الوظيفي؟')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jobId" value="@job.Id" />
                                    <input type="hidden" name="companyId" value="@company?.Id" />
                                    <button type="submit"
                                            style="background:#fef2f2;border:none;border-radius:var(--radius-sm);padding:4px 10px;font-size:12px;cursor:pointer;color:#dc2626">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Candidates Table -->
    <div style="background:var(--card-bg);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden">
        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <h2 style="font-size:14px;font-weight:700;margin:0">المرشحون المعيَّنون</h2>
            <span style="font-size:12px;color:var(--text-muted)">@assigned مرشح</span>
        </div>

        @{
            var candidates = ViewBag.Candidates as dynamic;
            bool hasCandidates = false;
            if (candidates != null) foreach (var _ in candidates) { hasCandidates = true; break; }
        }

        @if (!hasCandidates)
        {
            <div style="padding:40px;text-align:center">
                <div style="font-size:13px;color:var(--text-muted)">لم يتم تعيين أي مرشح لهذه الشركة بعد</div>
                <button onclick="openAssignModal()"
                        style="margin-top:12px;background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
                    <i class="bi bi-person-plus-fill me-1"></i> تعيين مرشح
                </button>
            </div>
        }
        else
        {
            <table class="table mb-0" style="font-size:13px">
                <thead style="background:#f8fafc">
                    <tr>
                        <th style="padding:12px 20px;font-weight:700;color:var(--text-muted);font-size:12px">المرشح</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px">الباقة</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px">المرحلة الحالية</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px">المدفوع</th>
                        <th style="font-weight:700;color:var(--text-muted);font-size:12px">الحالة</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cand in ViewBag.Candidates)
                    {
                        bool isDone = (bool)cand.IsCompleted;
                        <tr style="border-top:1px solid var(--border)">
                            <td style="padding:14px 20px">
                                <div style="font-weight:700">@cand.FullName</div>
                                <div style="font-size:11px;color:var(--text-muted)">@cand.Phone</div>
                            </td>
                            <td style="padding:14px 20px;color:var(--text-muted)">@cand.PackageName</td>
                            <td style="padding:14px 20px">
                                <span style="background:#eff6ff;color:var(--primary);padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600">
                                    @cand.CurrentStageName
                                </span>
                            </td>
                            <td style="padding:14px 20px;font-weight:600">
                                @(((decimal)cand.TotalPaidEgp).ToString("N0")) ج.م
                            </td>
                            <td style="padding:14px 20px">
                                @if (isDone)
                                {
                                    <span style="background:#f0fdf4;color:#16a34a;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600">
                                        <i class="bi bi-check-circle-fill me-1"></i>سافر
                                    </span>
                                }
                                else
                                {
                                    <span style="background:#fef9c3;color:#854d0e;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600">
                                        ● جاري
                                    </span>
                                }
                            </td>
                            <td style="padding:14px 20px;display:flex;gap:8px">
                                <a href="/Admin/CandidateDetail/@cand.Id"
                                   style="font-size:12px;color:var(--primary);text-decoration:none;font-weight:600">
                                    <i class="bi bi-eye me-1"></i>عرض
                                </a>
                                <form method="post" action="/Companies/UnassignCandidate" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="companyId" value="@company?.Id" />
                                    <input type="hidden" name="candidateId" value="@cand.Id" />
                                    <button type="submit"
                                            onclick="return confirm('إلغاء ربط هذا المرشح بالشركة؟')"
                                            style="background:none;border:none;font-size:12px;color:#ef4444;cursor:pointer;font-family:inherit;font-weight:600">
                                        <i class="bi bi-x-circle me-1"></i>إلغاء
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- ── Assign Candidate Modal ─────────────────────────────────────────────────── -->
<div id="assignModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg);border-radius:var(--radius);width:460px;max-width:95vw">
        <div style="padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <h5 style="margin:0;font-weight:800;font-size:15px">
                <i class="bi bi-person-plus-fill me-2" style="color:var(--primary)"></i>تعيين مرشح للشركة
            </h5>
            <button onclick="closeAssignModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted)">×</button>
        </div>
        <form method="post" action="/Companies/AssignCandidate" style="padding:22px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="companyId" value="@company?.Id" />
            <input type="hidden" name="candidateId" id="assignCandidateId" required />

            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">ابحث عن مرشح</label>
                <input type="text" id="assignSearch" class="form-control" style="font-size:13px"
                       placeholder="الاسم أو التليفون أو رقم الجواز..."
                       oninput="searchAssign(this.value)" autocomplete="off" />
                <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
                    يظهر فقط المرشحون غير المرتبطين بأي شركة
                </div>
                <div id="assignResults"
                     style="border:1px solid var(--border);border-top:none;border-radius:0 0 8px 8px;max-height:200px;overflow-y:auto;display:none;background:var(--card-bg)">
                </div>
                <div id="assignSelected"
                     style="display:none;margin-top:8px;background:#eff6ff;border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-weight:600;color:var(--primary)">
                </div>
            </div>

            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" onclick="closeAssignModal()"
                        style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;cursor:pointer;font-family:inherit">
                    إلغاء
                </button>
                <button type="submit" id="assignSubmitBtn" disabled
                        style="background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;opacity:.5">
                    <i class="bi bi-person-check-fill me-1"></i> تعيين
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── Add Job Modal ──────────────────────────────────────────────────────────── -->
<div id="addJobModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg);border-radius:var(--radius);width:420px;max-width:95vw">
        <div style="padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <h5 style="margin:0;font-weight:800;font-size:15px">➕ إضافة مسمى وظيفي</h5>
            <button onclick="document.getElementById('addJobModal').style.display='none'"
                    style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted)">
                ×
            </button>
        </div>
        <form method="post" action="/Companies/AddJob" style="padding:22px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="companyId" value="@company?.Id" />
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">المسمى الوظيفي <span style="color:var(--danger)">*</span></label>
                <input type="text" name="jobTitle" class="form-control" style="font-size:13px"
                       placeholder="مثال: سائق، محاسب، مهندس" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">العدد المطلوب</label>
                <input type="number" name="requestedCount" class="form-control" style="font-size:13px" min="1" value="1" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">ملاحظات</label>
                <input type="text" name="notes" class="form-control" style="font-size:13px" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" onclick="document.getElementById('addJobModal').style.display='none'"
                        style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;cursor:pointer;font-family:inherit">
                    إلغاء
                </button>
                <button type="submit"
                        style="background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
                    <i class="bi bi-plus me-1"></i> إضافة
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── Edit Job Modal ──────────────────────────────────────────────────────────── -->
<div id="editJobModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center">
    <div style="background:var(--card-bg);border-radius:var(--radius);width:420px;max-width:95vw">
        <div style="padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <h5 style="margin:0;font-weight:800;font-size:15px">✏️ تعديل المسمى الوظيفي</h5>
            <button onclick="document.getElementById('editJobModal').style.display='none'"
                    style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted)">
                ×
            </button>
        </div>
        <form method="post" action="/Companies/EditJob" style="padding:22px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="jobId" id="editJobId" />
            <input type="hidden" name="companyId" value="@company?.Id" />
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">المسمى الوظيفي <span style="color:var(--danger)">*</span></label>
                <input type="text" name="jobTitle" id="editJobTitle" class="form-control" style="font-size:13px" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">العدد المطلوب</label>
                <input type="number" name="requestedCount" id="editJobCount" class="form-control" style="font-size:13px" min="1" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size:13px">ملاحظات</label>
                <input type="text" name="notes" id="editJobNotes" class="form-control" style="font-size:13px" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" onclick="document.getElementById('editJobModal').style.display='none'"
                        style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;cursor:pointer;font-family:inherit">
                    إلغاء
                </button>
                <button type="submit"
                        style="background:var(--primary);color:#fff;border:none;border-radius:var(--radius-sm);padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
                    <i class="bi bi-check-lg me-1"></i> حفظ
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAssignModal() {
            document.getElementById('assignModal').style.display = 'flex';
            document.getElementById('assignSearch').focus();
        }
        function closeAssignModal() {
            document.getElementById('assignModal').style.display = 'none';
            document.getElementById('assignSearch').value = '';
            document.getElementById('assignResults').style.display = 'none';
            document.getElementById('assignSelected').style.display = 'none';
            document.getElementById('assignCandidateId').value = '';
            var btn = document.getElementById('assignSubmitBtn');
            btn.disabled = true; btn.style.opacity = '.5';
        }

        var assignTimeout;
        function searchAssign(q) {
            clearTimeout(assignTimeout);
            if (!q || q.length < 2) {
                document.getElementById('assignResults').style.display = 'none';
                return;
            }
            assignTimeout = setTimeout(async function() {
                const res  = await fetch('/Companies/SearchCandidates?q=' + encodeURIComponent(q));
                const data = await res.json();
                const box  = document.getElementById('assignResults');
                if (!data.length) {
                    box.innerHTML = '<div style="padding:12px 16px;font-size:12px;color:var(--text-muted)">لا توجد نتائج</div>';
                } else {
                    box.innerHTML = data.map(c => `
                        <div onclick="selectAssignCandidate('${c.id}','${c.fullName}','${c.passportNumber || ''}')"
                             style="padding:10px 16px;cursor:pointer;font-size:13px;border-bottom:1px solid var(--border)"
                             onmouseover="this.style.background='var(--hover-bg)'"
                             onmouseout="this.style.background=''">
                            <div style="font-weight:600">${c.fullName}</div>
                            <div style="font-size:11px;color:var(--text-muted)">
                                ${c.phone}
                                ${c.passportNumber ? '· ' + c.passportNumber : ''}
                                · ${c.packageName}
                            </div>
                        </div>
                    `).join('');
                }
                box.style.display = 'block';
            }, 300);
        }

        function selectAssignCandidate(id, name, passportNo) {
            document.getElementById('assignCandidateId').value = id;
            document.getElementById('assignSearch').value      = name;
            document.getElementById('assignResults').style.display = 'none';
            var sel = document.getElementById('assignSelected');
            sel.innerHTML = `<i class="bi bi-person-check-fill me-1"></i> ${name} ${passportNo ? '· ' + passportNo : ''}`;
            sel.style.display = 'block';
            var btn = document.getElementById('assignSubmitBtn');
            btn.disabled = false; btn.style.opacity = '1';
        }

        function openEditJobModal(id, title, count, notes) {
            document.getElementById('editJobId').value    = id;
            document.getElementById('editJobTitle').value = title;
            document.getElementById('editJobCount').value = count;
            document.getElementById('editJobNotes').value = notes;
            document.getElementById('editJobModal').style.display = 'flex';
        }
        document.addEventListener('click', function(e) {
            if (e.target === document.getElementById('assignModal')) closeAssignModal();
        });
    </script>
}
